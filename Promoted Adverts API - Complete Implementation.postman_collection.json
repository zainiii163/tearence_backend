	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-set auth token if available",
					"if (!pm.environment.get('auth_token') && pm.collectionVariables.get('temp_auth_token')) {",
					"    pm.environment.set('auth_token', pm.collectionVariables.get('temp_auth_token'));",
					"}",
					"",
					"// Auto-set admin token if available",
					"if (!pm.environment.get('admin_token') && pm.collectionVariables.get('temp_admin_token')) {",
					"    pm.environment.set('admin_token', pm.collectionVariables.get('temp_admin_token'));",
					"}",
					"",
					"// Log request details",
					"console.log('=== PROMOTED ADVERTS API REQUEST ===');",
					"console.log('Method:', pm.request.method.toUpperCase());",
					"console.log('URL:', pm.request.url.getPath());",
					"console.log('Headers:', pm.request.headers.toJSON());",
					"",
					"// Add request timestamp",
					"pm.request.headers.add({",
					"    key: 'X-Request-Timestamp',",
					"    value: new Date().toISOString()",
					"});",
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Basic response tests",
					"pm.test('Status code is successful', function () {",
					"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
					"});",
					"",
					"pm.test('Response has success field', function () {",
					"    const jsonData = pm.response.json();",
					"    pm.expect(jsonData).to.have.property('success');",
					"    pm.expect(jsonData.success).to.be.a('boolean');",
					"});",
					"",
					"pm.test('Response has data field for successful responses', function () {",
					"    const jsonData = pm.response.json();",
					"    if (jsonData.success) {",
					"        pm.expect(jsonData).to.have.property('data');",
					"    }",
					"});",
					"",
					"pm.test('Response time is reasonable', function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(5000);",
					"});",
					"",
					"pm.test('Content-Type is JSON', function () {",
					"    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
					"});",
					"",
					"// Store auth token from login responses",
					"if (pm.request.url.getPath().includes('login') && pm.response.code === 200) {",
					"    const jsonData = pm.response.json();",
					"    if (jsonData.data && jsonData.data.token) {",
					"        pm.environment.set('auth_token', jsonData.data.token);",
					"        console.log('✅ Auth token stored');",
					"    }",
					"}",
					"",
					"// Store admin token from admin login",
					"if (pm.request.url.getPath().includes('admin') && pm.request.url.getPath().includes('login') && pm.response.code === 200) {",
					"    const jsonData = pm.response.json();",
					"    if (jsonData.data && jsonData.data.token) {",
					"        pm.environment.set('admin_token', jsonData.data.token);",
					"        console.log('✅ Admin token stored');",
					"    }",
					"}",
					"",
					"// Test pagination structure for list endpoints",
					"if (pm.request.url.getPath().includes('/promoted-adverts') && pm.request.method === 'GET' && !pm.request.url.getPath().includes('/')) {",
					"    pm.test('List response has pagination structure', function () {",
					"        const jsonData = pm.response.json();",
					"        if (jsonData.success && jsonData.data) {",
					"            pm.expect(jsonData.data).to.have.property('data');",
					"            pm.expect(jsonData.data).to.have.property('current_page');",
					"            pm.expect(jsonData.data).to.have.property('per_page');",
					"            pm.expect(jsonData.data).to.have.property('total');",
					"        }",
					"    });",
					"}",
					"",
					"// Test validation error structure",
					"if (pm.response.code === 422) {",
					"    pm.test('Validation error has correct structure', function () {",
					"        const jsonData = pm.response.json();",
					"        pm.expect(jsonData).to.have.property('success', false);",
					"        pm.expect(jsonData).to.have.property('errors');",
					"        pm.expect(jsonData.errors).to.be.an('object');",
					"    });",
					"}",
					"",
					"// Test analytics tracking",
					"if (pm.request.url.getPath().includes('track-click')) {",
					"    pm.test('Click tracking response', function () {",
					"        const jsonData = pm.response.json();",
					"        pm.expect(jsonData).to.have.property('success', true);",
					"        pm.expect(jsonData).to.have.property('message');",
					"    });",
					"}",
					"",
					"// Test file upload response",
					"if (pm.request.url.getPath().includes('upload')) {",
					"    pm.test('File upload response structure', function () {",
					"        const jsonData = pm.response.json();",
					"        if (jsonData.success) {",
					"            pm.expect(jsonData.data).to.be.an('array');",
					"            if (jsonData.data.length > 0) {",
					"                pm.expect(jsonData.data[0]).to.be.a('string');",
					"                pm.expect(jsonData.data[0]).to.include('storage');",
					"            }",
					"        }",
					"    });",
					"}",
					"",
					"// Log response details",
					"console.log('=== PROMOTED ADVERTS API RESPONSE ===');",
					"console.log('Status:', pm.response.code);",
					"console.log('Response Time:', pm.response.responseTime + 'ms');",
					"console.log('Success:', pm.response.json().success);",
					"",
					"// Performance warnings",
					"if (pm.response.responseTime > 3000) {",
					"    console.warn('⚠️ Slow response detected:', pm.response.responseTime + 'ms');",
					"}",
					""
				]
			}
		}
