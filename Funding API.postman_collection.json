							"raw": "{\n    \"title\": \"Revolutionary Eco-Friendly Water Purifier\",\n    \"tagline\": \"Clean water for everyone, everywhere\",\n    \"project_type\": \"startup\",\n    \"category\": \"technology\",\n    \"description\": \"A breakthrough water purification system that uses solar energy and natural filtration to provide clean drinking water in remote areas.\",\n    \"problem_solved\": \"Over 2 billion people lack access to clean drinking water. Existing solutions are expensive and require constant maintenance.\",\n    \"vision_mission\": \"To provide affordable, sustainable clean water solutions to communities worldwide.\",\n    \"why_matters_now\": \"Climate change is worsening water scarcity. Our solution is needed more than ever.\",\n    \"funding_goal\": 50000,\n    \"minimum_contribution\": 25,\n    \"funding_model\": \"reward_based\",\n    \"funding_deadline\": \"2024-12-31\",\n    \"risk_level\": \"medium\",\n    \"country\": \"United Kingdom\",\n    \"region\": \"London\",\n    \"pitch_video_url\": \"https://youtube.com/watch?v=example\",\n    \"team_members\": [\n        {\n            \"name\": \"John Smith\",\n            \"role\": \"CEO & Founder\",\n            \"photo\": \"https://example.com/john.jpg\"\n        },\n        {\n            \"name\": \"Jane Doe\",\n            \"role\": \"CTO\",\n            \"photo\": \"https://example.com/jane.jpg\"\n        }\n    ],\n    \"use_of_funds\": [\n        {\n            \"item\": \"Research & Development\",\n            \"amount\": 20000\n        },\n        {\n            \"item\": \"Manufacturing Setup\",\n            \"amount\": 15000\n        },\n        {\n            \"item\": \"Marketing & Distribution\",\n            \"amount\": 10000\n        },\n        {\n            \"item\": \"Operations\",\n            \"amount\": 5000\n        }\n    ],\n    \"milestones\": [\n        {\n            \"title\": \"Prototype Completion\",\n            \"date\": \"2024-06-30\",\n            \"description\": \"Finalize and test the working prototype\"\n        },\n        {\n            \"title\": \"Manufacturing Start\",\n            \"date\": \"2024-09-30\",\n            \"description\": \"Begin mass production\"\n        },\n        {\n            \"title\": \"First Shipments\",\n            \"date\": \"2024-11-30\",\n            \"description\": \"Deliver first batch to customers\"\n        }\n    ],\n    \"social_links\": {\n        \"twitter\": \"https://twitter.com/waterpurifier\",\n        \"facebook\": \"https://facebook.com/waterpurifier\",\n        \"linkedin\": \"https://linkedin.com/company/waterpurifier\"\n    },\n    \"revenue_model\": \"Direct B2C sales and B2B partnerships with NGOs and government agencies\",\n    \"forecasts\": \"Year 1: £100k, Year 2: £500k, Year 3: £2M\",\n    \"risk_disclosures\": \"Regulatory approval risks, supply chain disruptions, market competition\",\n    \"website\": \"https://waterpurifier.com\",\n    \"rewards\": [\n        {\n            \"title\": \"Early Bird Supporter\",\n            \"description\": \"Get your purifier at 30% off retail price\",\n            \"minimum_contribution\": 25,\n            \"limit\": 100,\n            \"estimated_delivery_date\": \"2024-12-15\"\n        },\n        {\n            \"title\": \"Eco Warrior\",\n            \"description\": \"Purifier + exclusive updates + name on website\",\n            \"minimum_contribution\": 100,\n            \"limit\": 50,\n            \"estimated_delivery_date\": \"2024-12-15\"\n        },\n        {\n            \"title\": \"Impact Partner\",\n            \"description\": \"5 purifiers + plant a tree for each unit + virtual meeting with founders\",\n            \"minimum_contribution\": 500,\n            \"limit\": 20,\n            \"estimated_delivery_date\": \"2024-12-15\"\n        }\n    ]\n}"
