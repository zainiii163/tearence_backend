{
  "info": {
    "name": "Resorts & Travel API",
    "description": "Complete API collection for Resorts & Travel marketplace system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/resorts-travel/categories",
              "host": ["{{base_url}}"],
              "path": ["resorts-travel", "categories"]
            }
          }
        }
      ]
    },
    {
      "name": "Travel Adverts",
      "item": [
        {
          "name": "Get All Adverts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/resorts-travel",
              "host": ["{{base_url}}"],
              "path": ["resorts-travel"]
            }
          }
        },
        {
          "name": "Get Featured Adverts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/resorts-travel/featured",
              "host": ["{{base_url}}"],
              "path": ["resorts-travel", "featured"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8001/api/v1"
    },
    {
      "key": "token",
      "value": "your_api_token_here"
    }
  ]
}
